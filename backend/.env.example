# Database
MONGODB_URI=mongodb://localhost:27017/hospital-booking

# JWT
JWT_SECRET=your_jwt_secret_key_change_this
JWT_EXPIRE=7d

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# SMS Configuration (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Payment Gateways
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_PUBLIC_KEY=pk_test_xxxxx

PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox

RAZORPAY_KEY_ID=your_razorpay_key
RAZORPAY_KEY_SECRET=your_razorpay_secret

# App Configuration
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# Google Pay & PhonePe Configuration
GOOGLE_PAY_MERCHANT_ID=your_google_pay_merchant_id
PHONPE_MERCHANT_ID=your_phonpe_merchant_id
PHONPE_API_KEY=your_phonpe_api_key

# Paytm Configuration
PAYTM_MERCHANT_KEY=your_paytm_merchant_key
PAYTM_MERCHANT_ID=your_paytm_merchant_id

# Admin Panel
ADMIN_EMAIL=admin@hospital.com
ADMIN_PASSWORD=admin@123
